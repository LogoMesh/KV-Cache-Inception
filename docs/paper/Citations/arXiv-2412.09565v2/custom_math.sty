% \let\varphi\temp

\newcommand{\R}{\ensuremath{\mathbb{R}}}
\newcommand{\N}{\ensuremath{\mathbb{N}}}
\newcommand{\Z}{\ensuremath{\mathbb{Z}}}

\newcommand{\eps}{\varepsilon}

\newcommand{\E}{\mathop{\mb{E}}} % expected value
% Black magic from https://tex.stackexchange.com/questions/308/different-command-definitions-with-and-without-optional-argument
% usage: \expval[x \sim \mathcal{P}]{x^2}
% or simply \expval{x^2} if the distribution is clear
\makeatletter
\def\expval{\@ifnextchar[{\@withE}{\@withoutE}}
\def\@withE[#1]#2{\E_{#1}\left[ #2 \right]}
\def\@withoutE#1{\E\left[ #1 \right]}
\makeatother

\makeatletter
\def\Pr{\@ifnextchar[{\@withPr}{\@withoutPr}}
\def\@withPr[#1]#2{\operatorname*{Pr}_{#1}\left[ #2 \right]}
\def\@withoutPr#1{\operatorname*{Pr}\left[ #1 \right]}
\makeatother

\DeclarePairedDelimiterX{\doublebar}[2]{(}{)}{%
  #1\;\delimsize\|\;#2%
}
\newcommand{\kl}{D_{KL}\doublebar}

%%%%%%%%%%%%%%%%%%%%
% Paper variables
%%%%%%%%%%%%%%%%%%%%
\newcommand{\model}{\ensuremath{M}}
% Representations of input for a given model.
% Usage: \repr[layer]{input}{model}  -> R(input; model)_layer
% or: \repr{input}{model}           -> R(input; model)
% or: \repr{input}                  -> R(input)
\makeatletter
\def\repr{\@ifnextchar[{\@withrepr}{\@withoutrepr}}
\def\@withrepr[#1]#2{\@ifnextchar\bgroup{\@withreplayer[#1]{#2}}{\ensuremath{\mc{R}(#2)_{#1}}}}
\def\@withreplayer[#1]#2#3{\ensuremath{\mc{R}(#2; #3)_{#1}}}
\def\@withoutrepr#1{\@ifnextchar\bgroup{\@withreprmodel{#1}}{\ensuremath{\mc{R}(#1)}}}
\def\@withreprmodel#1#2{\ensuremath{\mc{R}(#1; #2)}}
\makeatother
